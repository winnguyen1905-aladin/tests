# SAM3 Configuration - Development
# Copy to .env and customize as needed

# Environment
ENV=dev

# API
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://sam3user:sam3pass@localhost:5432/sam3?schema=public

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=tree_features

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tree-features
MINIO_SECURE=false

# Models
SAM3_MODEL_PATH=sam3.pt
SAM3_DEVICE=cuda
SAM3_CONFIDENCE=0.05

DINO_DEVICE=cuda
# DINOv3 *pretrain* weights are gated. Log in on huggingface.co, open the model page, click
# "Agree and access repository", then set a read token via ONE of (do not set empty DINO_HF_TOKEN=):
DINO_HF_TOKEN=hf_...
HF_TOKEN=hf_...
DINO_MODEL_TYPE=dinov3-vitb16-pretrain-lvd1689m
MILVUS_VECTOR_DIM=384
POSTGRES_VECTOR_DIM=384

# SuperPoint & LightGlue
SP_DEVICE=cuda
SP_MAX_KEYPOINTS=4096
LG_DEVICE=cuda

# Performance
MODEL_MODE=ultra
INGEST_CONCURRENCY=4

# Logging
LOG_LEVEL=INFO
# LOG_FILE=logs/sam3.log   # uncomment to enable rotating file logging

