# ============================================================
# SAM3 Production Environment Variables
# ============================================================
# Copy this file to .env.prod and fill in the values.
# DO NOT commit .env.prod to version control!
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENV=prod

# ── API ──────────────────────────────────────────────────────
API_PORT=8001
HTTP_PORT=80
HTTPS_PORT=443
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=sam3
POSTGRES_USER=sam3user
POSTGRES_PASSWORD=<STRONG_PASSWORD_HERE>
POSTGRES_PORT=5432

# ── Milvus ────────────────────────────────────────────────────
MILVUS_PORT=19530
MILVUS_USE_GPU=false
MILVUS_INDEX_BUILD_CONCURRENCY=16
MILVUS_QUERY_NODE_CONCURRENCY=256

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=<MINIO_ADMIN_USER>
MINIO_ROOT_PASSWORD=<STRONG_MINIO_PASSWORD>
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_IMAGE_TAG=latest

# ── SAM3 Models ────────────────────────────────────────────────
SAM3_DEVICE=cuda
DINO_DEVICE=cuda
LG_DEVICE=cuda
SP_DEVICE=cuda
MODEL_MODE=ultra
DINO_HF_TOKEN=<YOUR_HUGGINGFACE_TOKEN>

# ── Feature Extraction ────────────────────────────────────────
MILVUS_VECTOR_DIM=384
POSTGRES_VECTOR_DIM=384
MILVUS_COLLECTION=tree_features
MILVUS_TOP_K=100
MILVUS_SEARCH_TOP_K=100
VECTOR_STORE_TYPE=postgres

# ── Matching ─────────────────────────────────────────────────
COARSE_THRESHOLD=0.5
INLIER_THRESHOLD=8
MIN_MATCHES=15
MIN_INLIERS=7

# ── Geo Filters ───────────────────────────────────────────────
GEO_RADIUS_METERS=10.0
HOR_ANGLE_RANGE=30.0
VER_ANGLE_RANGE=60.0
PITCH_RANGE=75.0

# ── Performance ────────────────────────────────────────────────
INGEST_CONCURRENCY=4
SP_MAX_KEYPOINTS=4096
LG_FILTER_THRESHOLD=0.5
LG_CONFIDENCE=0.1

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/app/logs/sam3.log

# ── Security ──────────────────────────────────────────────────
API_KEY=<STRONG_API_KEY_HERE>

# ── Attu (Milvus Web UI) ──────────────────────────────────────
ATTU_PORT=8000

# ── GPU Settings ──────────────────────────────────────────────
# Fraction of GPU memory to allocate (0.0-1.0)
TORCH_MEMORY_FRACTION=0.85
